<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/upload_button"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:layout_marginStart="2dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="0"
                android:background="@drawable/upload_button"
                android:text="@string/upload_button" />

            <Button
                android:id="@+id/upload_wdg_button"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:layout_marginStart="2dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="0"
                android:background="@drawable/upload_button"
                android:text="@string/upload_wdg_button" />

            <LinearLayout
                android:id="@+id/gps_searching"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_weight="11"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/gps_searching_anim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:contentDescription="@string/list_waiting_gps"
                    android:paddingTop="2dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/animated_gps_searching"
                    app:tint="?attr/colorControlNormal" />

                <TextView
                    android:id="@+id/gps_searching_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:text="@string/list_waiting_gps" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/gps_area"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="11"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:layout_weight="6"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/lat_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:scrollHorizontally="true"
                        tools:text="Lon: 32.72387801" />

                    <TextView
                        android:id="@+id/lon_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Lon: -108.44456771" />

                    <TextView
                        android:id="@+id/speed_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Speed: 88 mph" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:layout_weight="5"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/accuracy_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="+/- 160 ft"

                        />

                    <TextView
                        android:id="@+id/alt_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Alt: 888 ft" />

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/not_scanning"
                    android:layout_width="44dip"
                    android:layout_height="44dip"
                    android:layout_margin="5dip"
                    android:background="#00000000"
                    android:contentDescription="@string/dash_scan_off"
                    android:paddingStart="3dip"
                    android:paddingTop="1dip"
                    android:paddingEnd="1dip"
                    android:paddingBottom="1dip"
                    android:src="@drawable/no_scan"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/scanning"
                    android:layout_width="46dip"
                    android:layout_height="46dip"
                    android:layout_margin="5dip"
                    android:background="#00000000"
                    android:contentDescription="@string/list_scanning_on"
                    android:paddingStart="3dip"
                    android:paddingTop="1dip"
                    android:paddingEnd="1dip"
                    android:paddingBottom="1dip"
                    android:scaleType="fitCenter"
                    android:visibility="gone"
                    app:srcCompat="@drawable/ic_wifi_simplified"
                    app:tint="?attr/colorControlNormal"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/sats_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Sats: 22"

                    />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/list_run_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_weight="4"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text=""
                tools:text="8,888,888 km" />

            <TextView
                android:id="@+id/scan_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_weight="1"
                android:text="@string/list_status_default"
                tools:text="888 scanned in 8888ms." />

            <TextView
                android:id="@+id/db_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_weight="0"
                android:paddingStart="3dp"
                android:paddingEnd="5dp"
                tools:text="DB Queue: 888" />
        </LinearLayout>

        <ListView
            android:id="@+id/ListView01"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="6"
            android:background="#00000000"
            tools:listitem="@layout/row" />

    </LinearLayout>

</LinearLayout>
