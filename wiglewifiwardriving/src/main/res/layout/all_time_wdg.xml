<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/topCardSection"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="4dp">

    <LinearLayout
        android:id="@+id/currentRun"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="4dp"
        tools:layout_editor_absoluteY="4dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="7dp"
            android:layout_marginBottom="5dp"
            android:fontFamily="@font/main_proto_font"
            android:text="WDG Wars Stats"
            android:textColor="#efefef"
            android:textSize="25dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/wdgtotalcaption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="7dp"
                    android:fontFamily="@font/main_proto_font"
                    android:text="@string/total_stats"
                    android:textColor="#EFEFEF"
                    android:textSize="16sp"
                    tools:text="Total" />

                <TextView
                    android:id="@+id/wdgnets"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="7dp"
                    android:fontFamily="@font/main_proto_font"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:textColor="#CECECE"
                    android:textSize="30dp"
                    tools:ignore="RtlSymmetry"
                    tools:text="8,888,888" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/wdgwifi"
                    style="@style/CellColor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/main_proto_font"
                    android:paddingEnd="10dp"
                    android:textSize="20dp"
                    tools:ignore="RtlSymmetry"
                    tools:text="8,888,888" />

                <TextView
                    android:id="@+id/wdgbt"
                    style="@style/BtColor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/main_proto_font"
                    android:paddingEnd="10dp"
                    android:textSize="20dp"
                    tools:ignore="RtlSymmetry"
                    tools:text="8,888,888" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>