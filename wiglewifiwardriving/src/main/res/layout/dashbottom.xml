<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent">
    <TextView
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:id="@+id/currnets"
        android:textSize="24sp"
        tools:text="@string/dash_vis_nets"
    />

    <TextView
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:id="@+id/rundist"
        android:textSize="24sp"
        tools:text="@string/dash_dist_run"
    />

    <TextView
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:id="@+id/dbNets"
        android:textSize="24sp"
        tools:text="@string/dash_db_nets"
    />

    <TextView
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:id="@+id/scanned_in"
        android:textSize="24sp"
        tools:text="@string/scanned_in"
    />
</LinearLayout>
